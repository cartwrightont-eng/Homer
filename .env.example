# ==== DATABASE CONFIGURATION ====
# Required: PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/university_app

# ==== ENVIRONMENT ====
FLASK_ENV=development
# Set to 'production' to enforce security requirements

# ==== JWT CONFIGURATION ====
# Required in production: Use a strong, random string of at least 32 characters
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Token expiry in hours
JWT_EXPIRES_HOURS=24
EMAIL_TOKEN_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_HOURS=2

# ==== PAGINATION CONFIGURATION ====
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==== VALIDATION CONFIGURATION ====
MAX_PRICE=10000000
MAX_DISTANCE_KM=100
MAX_STRING_LENGTH=500
MAX_DESCRIPTION_LENGTH=5000

# ==== SECURITY CONFIGURATION ====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ==== OPTIONAL: FLASK SECRET KEY ====
# Falls back to JWT_SECRET_KEY if not set
# FLASK_SECRET_KEY=your-flask-secret-key
